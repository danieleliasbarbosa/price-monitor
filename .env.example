# SerpApi — Walmart Product API
# Docs: https://serpapi.com/walmart-product-api
# Dashboard: https://serpapi.com/manage-api-key

SERPAPI_API_KEY=
# Recommended: your store's store_id (without it SerpApi may use the wrong default store)
# SERPAPI_WALMART_STORE_ID=2280
# Or a known ZIP (e.g. 94080 → store 2280 Mountain View)
# SERPAPI_WALMART_ZIP=94080

# Dashboard session secret (optional; generated in .data/session.secret)
# PRICE_MONITOR_SECRET=

# Resend — alerts and password reset
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=
# Test sender (only delivers to your Resend account email) or a verified domain address
EMAIL_FROM=onboarding@resend.dev
# App base URL (used in password-reset email links)
APP_BASE_URL=http://127.0.0.1:8765

# SMTP fallback (optional; only if not using Resend)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_TO=
