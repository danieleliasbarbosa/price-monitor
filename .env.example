# SerpApi — Walmart Product API
# Docs: https://serpapi.com/walmart-product-api
# Dashboard: https://serpapi.com/manage-api-key

SERPAPI_API_KEY=
# Recomendado: store_id da sua loja (sem isso a SerpApi usa loja default errada)
# SERPAPI_WALMART_STORE_ID=2280
# Ou ZIP conhecido (ex.: 94080 → store 2280 Mountain View)
# SERPAPI_WALMART_ZIP=94080

# Segredo das sessões do dashboard (opcional; gerado em .data/session.secret)
# PRICE_MONITOR_SECRET=

# Resend — alertas e redefinição de senha
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=
# Remetente de teste (só envia para o e-mail da conta Resend) ou domínio verificado
EMAIL_FROM=onboarding@resend.dev
# URL base do app (links no e-mail de reset)
APP_BASE_URL=http://127.0.0.1:8765

# Fallback SMTP (opcional; só se não usar Resend)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_TO=
